            'auth_email' =3D&gt; 'exemplo@gmail.com',
            'auth_token' =3D&gt; '72AE21503DDA4840BE1DC7945F6D1CE1'
                 ];
sc_call_api('',$arr_settings);
</pre><p>&nbsp;</p><p><strong>Exemplo 5 - Usando a macro com PayPal</strong=
></p><pre>  $arr_settings =3D [
