</td>
</tr>
<tr>
<td align=3D"left" valign=3D"top">['server']</td>
<td align=3D"left" valign=3D"top">Servidor do banco de dados</td>
<td align=3D"left" valign=3D"top">$arr_conn['server'] =3D "127.0.0.1"</td>
</tr>
<tr>
<td align=3D"left" valign=3D"top">['user']</td>
<td align=3D"left" valign=3D"top">Usu=C3=A1rio do banco de dados</td>
<td align=3D"left" valign=3D"top">$arr_conn['user'] =3D "root"</td>
</tr>
<tr>
<td align=3D"left" valign=3D"top">['password']</td>
<td align=3D"left" valign=3D"top">Senha do banco de dados</td>
<td align=3D"left" valign=3D"top">$arr_conn['password'] =3D "secretpass123"=
</td>
</tr>
<tr>
<td align=3D"left" valign=3D"top">['database']</td>
<td align=3D"left" valign=3D"top">Base de dados utilizada pela conex=C3=A3o=
</td>
<td align=3D"left" valign=3D"top">$arr_conn['database'] =3D "sc_samples"</t=
d>
</tr>
<tr>
<td align=3D"left" valign=3D"top">['persistent']</td>
<td align=3D"left" valign=3D"top">Define se a conex=C3=A3o ser=C3=A1 persis=
tente ou n=C3=A3o</td>
<td align=3D"left" valign=3D"top">$arr_conn['persistent'] =3D "Y" / "N"</td=
>
</tr>
<tr>
<td align=3D"left" valign=3D"top">['encoding']</td>
<td align=3D"left" valign=3D"top">Configura o encoding da conex=C3=A3o</td>
<td align=3D"left" valign=3D"top">$arr_conn['encoding'] =3D "utf8"</td>
</tr>
</tbody>
</table>
