</tr>
<tr>
<td class=3D"corpo1" align=3D"left" valign=3D"top">Simb_Dec</td>
<td class=3D"corpo1" align=3D"left" valign=3D"top"><span class=3D"corpo1">S=
=C3=ADmbolo para o separador de decimais.</span></td>
</tr>
<tr>
<td class=3D"corpo1" align=3D"left" valign=3D"top">Qtde_Dec</td>
