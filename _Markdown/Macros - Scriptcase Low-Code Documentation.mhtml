<p><strong>3. Utilizando foreach e consulta no banco de dados</strong></p><=
pre>sc_appmenu_create("menu");

// Home
sc_appmenu_add_item("menu", "item_0", "", "Home", "app_home", "", "fa fa-ho=
me", "P=C3=A1gina inicial", "_self", "");

// Consulta com JOIN
sc_lookup(menu_data, "
  SELECT
    g.id AS grupo_id,
    g.nome AS grupo_nome,
    i.id AS item_id,
    i.nome AS item_nome,
    i.app AS app,
    i.icone AS icone
  FROM grupos g
  JOIN itens i ON i.grupo_id =3D g.id
  WHERE g.ativo =3D 'S' AND i.ativo =3D 'S'
  ORDER BY g.id, i.id
");

$grupos_criados =3D array();

if (isset({menu_data[0][0]})) {
  foreach ({menu_data} as $linha) {
    $grupo_id   =3D "item_" . $linha[0];
    $grupo_nome =3D $linha[1];
    $item_id    =3D "item_" . $linha[2];
    $item_nome  =3D $linha[3];
    $item_app   =3D $linha[4];
    $item_icone =3D $linha[5];

    if (!in_array($grupo_id, $grupos_criados)) {
      sc_appmenu_add_item("menu", $grupo_id, "", $grupo_nome, "", "", "fa f=
a-folder", "", "", "");
      $grupos_criados[] =3D $grupo_id;
    }

    sc_appmenu_add_item("menu", $item_id, $grupo_id, $item_nome, $item_app,=
 "", $item_icone, "", "_self", "");
  }
}
</pre>
