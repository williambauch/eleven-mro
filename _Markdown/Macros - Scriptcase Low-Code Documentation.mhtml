<li><strong><span style=3D"color: #000000;">Vari=C3=A1veis - </span></stron=
g><span style=3D"color: #000000;">Locais ou globais.&nbsp;</span><strong>Ex=
.:</strong>&nbsp;<code><span style=3D"color: #000000;">$new_label</span></c=
ode></li>
<li><strong><span style=3D"color: #000000;">Lang -&nbsp;</span></strong><sp=
an style=3D"color: #000000;">vari=C3=A1vel lang. <strong>Ex.:</strong>&nbsp=
;<code>{lang_btn_label}</code></span></li>
</ul>
</td>
<td style=3D"width: 49.6124%; height: 18px;">
