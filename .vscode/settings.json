        "/^python -c \"\ncontent = '''<\\?php\n\n// Verificar envio de email para admin \\(se configurado nas settings\\)\n\\\\\\$var_send_email = isset\\(\\[sett_send_email_adm\\]\\) \\? \\[sett_send_email_adm\\] : 'N';\nif \\(\\\\\\$var_send_email == 'Y'\\) \\{\n    send_mail_to_admin\\(\\);\n\\}\n\n// Verificar envio de email de ativacao \\(se configurado\\)\n\\\\\\$var_req_email = isset\\(\\[sett_req_email_act\\]\\) \\? \\[sett_req_email_act\\] : 'N';\nif \\(\\\\\\$var_req_email == 'Y'\\) \\{\n    send_mail_to_new_user\\(\\);\n\\}\n\nadd_user_to_group\\(\\{login\\}\\);\n\nsc_commit_trans\\(\\);\nsc_redir\\('app__Login', return_msg_email_act=0\\);\n'''\nwith open\\('C:\\\\\\\\\\\\\\\\xampp\\\\\\\\\\\\\\\\htdocs\\\\\\\\\\\\\\\\gestor_xml\\\\\\\\\\\\\\\\Security\\\\\\\\\\\\\\\\app__form_edit_users\\\\\\\\\\\\\\\\events\\\\\\\\\\\\\\\\11_onAfterInsert\\\\\\\\\\\\\\\\onAfterInsert\\.scriptcase', 'w', encoding='utf-8'\\) as f:\n    f\\.write\\(content\\)\nprint\\('OK'\\)\n\"$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "%": true,
