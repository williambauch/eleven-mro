<?php

// Se o motivo for Almoço (ID 1), esconde a obrigatoriedade. Caso contrário, exige a nota.
if ({motivo_pausa} == 1) {
    sc_field_display({passagem_servico}, 'off');
    // Ou pode apenas tirar a obrigatoriedade: sc_req({passagem_servico}, 'off');
} else {
    sc_field_display({passagem_servico}, 'on');
    // Torna o preenchimento obrigatório para compliance
    sc_req({passagem_servico}, 'on'); 
}
