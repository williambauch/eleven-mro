        <td>190036</td>
        <td>'. $data['ata'] .'</td>
        <td>'. $data['ac_type'] .'</td>
        <td>'. $data['ac_reg'] .'</td>
        <td>A320</td>
    </tr>
</table>

<br/>
<h3>Equipments & Tools [cite: 110]</h3>
<table cellpadding="5">
    <thead>
        <tr style="background-color:#ccc;">
            <th width="20%">Tool Code</th>
            <th width="60%">Description</th>
            <th width="20%">Qty</th>
        </tr>
    </thead>
    <tbody>
        <tr><td height="30">&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td></tr>
        <tr><td height="30">&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td></tr>
        <tr><td height="30">&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td></tr>
        <tr><td height="30">&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td></tr>
    </tbody>
</table>

<br/><br/>
<div style="text-align:right; font-size:8pt;">TF-53-003 - Rev. 00</div>
';

$pdf->writeHTML($html_p2, true, false, true, false, '');

// Saída do PDF
$pdf->Output('NonRoutine_Card.pdf', 'I');
