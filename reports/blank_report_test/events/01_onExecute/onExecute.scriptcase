        </td>
    </tr>
</table>

<br/>
<table cellpadding="3">
    <tr style="background-color:#ddd;">
        <th>Origin Doc</th>
        <th>ATA</th>
        <th>A/C Type</th>
        <th>A/C Reg</th>
        <th>Company</th>
