    <tr align="center">
        <td>'.$d['origin'].'</td><td>'.$d['ata'].'</td><td>'.$d['model'].'</td>
        <td>'.$d['reg'].'</td><td>'.$d['comp'].'</td><td>'.$d['wo'].'</td>
    </tr>
</table>
<br>
<div style="font-weight:bold; font-size:10pt; border-bottom:1px solid black; margin-bottom:5px;">Materials</div>
<table cellpadding="4">
    <tr class="box-title">
        <th width="15%">P/N</th>
        <th width="5%">Unit</th>
        <th width="10%">Qty</th>
        <th width="15%">P/N IW</th>
        <th width="15%">Batch / SN</th>
        <th width="25%">Description</th>
        <th width="15%">Mat. Applied?</th>
    </tr>
    ' . $linhas_materiais . '
</table>
<br><br>
<table cellpadding="5" border="0">
    <tr>
        <td width="50%" style="border-bottom:1px solid black;">&nbsp;</td>
        <td width="10%">&nbsp;</td>
        <td width="40%" style="border-bottom:1px solid black;">&nbsp;</td>
    </tr>
    <tr>
        <td align="center">Provider (Sign & Stamp)</td>
        <td></td>
        <td align="center">Requester (Sign & Stamp)</td>
    </tr>
</table>
';
$pdf->writeHTML($html3, true, false, true, false, '');

// =============================================================================
// PÁGINA 4: SHIFT TURNOVER
// =============================================================================
$pdf->AddPage();

$html4 = $style . '
<div style="text-align:center; font-weight:bold; font-size:12pt; background-color:#E6E6E6; border:1px solid black; padding:5px;">
    SHIFT TURNOVER (PASSAGEM DE SERVIÇO)
</div>
<br>
<table cellpadding="3">
    <tr>
        <td><b>A/C Type:</b> '.$d['model'].'</td>
        <td><b>A/C Reg:</b> '.$d['reg'].'</td>
        <td><b>Card Code:</b> '.$d['code'].'</td>
    </tr>
</table>
<br>
<table cellpadding="5">
    <tr class="box-title">
        <th width="65%">ACTION (Ação)</th>
